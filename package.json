{
  "name": "betynz-chronos-fusion",
  "private": true,
  "version": "2.8.2",
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "scripts": {
    "dev": "concurrently -n API,WEB -c auto \"npm run dev -w apps/api\" \"npm run dev -w apps/web\"",
    "build": "npm run build -w apps/api && npm run build -w apps/web",
    "start": "npm run start -w apps/api",
    "import:local": "npm run import:local -w apps/api",
    "test:engine": "npm run test:engine -w apps/api",
    "test:betexplorer-parser": "npm run test:betexplorer-parser -w apps/api",
    "test:streak-parser": "npm run test:streak-parser -w apps/api",
    "test:ares": "npm run test:ares -w apps/api",
    "test:sync-rescue": "npm run test:sync-rescue -w apps/api"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
