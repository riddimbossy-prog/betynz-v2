# Frontend
VITE_API_BASE_URL=http://localhost:8787

# API
PORT=8787
CORS_ORIGINS=http://localhost:5173,https://betynz.com,https://www.betynz.com
ADMIN_IMPORT_TOKEN=replace-with-a-long-random-secret

# Supabase server credentials. Never put the service-role key in the frontend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Live fixtures and bookmaker odds
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# Six-day board = today plus the next five days
PREDICTION_DAYS=6
PREDICTION_TIMEZONE=Africa/Accra

# Optional: restrict fixture syncing to selected API-Football league IDs.
# Leave blank for all available fixtures. Example EPL: 39
API_FOOTBALL_LEAGUE_IDS=
API_FOOTBALL_SEASON=

# Optional JSON aliases when provider team names differ from Football-Data names.
# Example: {"manchesterunited":"manunited"}
TEAM_ALIASES_JSON={}
