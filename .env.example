# Frontend
VITE_API_BASE_URL=http://localhost:8787

# API
PORT=8787
CORS_ORIGINS=http://localhost:5173,https://betynz.com,https://www.betynz.com
ADMIN_IMPORT_TOKEN=replace-with-a-long-random-secret

# Supabase server credentials. Never put the service-role key in the frontend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# BetExplorer stays primary. v2.8.2 keeps automatic provider rescue and adds independent Ares grading.
FIXTURE_PROVIDER=betexplorer
AUTO_PROVIDER_RESCUE=true
BETEXPLORER_ENABLED=true
BETEXPLORER_BASE_URL=https://www.betexplorer.com
BETEXPLORER_UTC_OFFSET_MINUTES=0
BETEXPLORER_BROWSER_TIMEOUT_MS=65000
BETEXPLORER_BROWSER_RETRIES=2
BETEXPLORER_BROWSER_BUDGET_MS=600000
BETEXPLORER_DIRECT_URL_TEMPLATES=https://www.betexplorer.com/football/?year={YYYY}&month={MM}&day={DD};https://www.betexplorer.com/next/soccer/?year={YYYY}&month={MM}&day={DD};https://www.betexplorer.com/?year={YYYY}&month={MM}&day={DD}
BETEXPLORER_BROWSER_LANDING_URLS=https://www.betexplorer.com/football/;https://www.betexplorer.com/next/soccer/
BETEXPLORER_BROWSER_RATE_MS=1800
BETEXPLORER_LEAGUE_PAGE_LIMIT=120
BETEXPLORER_NO_NEW_STOP=24
BETEXPLORER_MIN_LEAGUE_PAGES=40
BETEXPLORER_BROWSER_JITTER_MS=500
BETEXPLORER_INTELLIGENCE_TAB_LIMIT=2
BETEXPLORER_FAILURE_DIAGNOSTICS=true

# API-Football rescue feed. Leave league IDs blank for all-league date discovery.
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_TIMEZONE=Africa/Accra
API_FOOTBALL_MAX_ODDS_PAGES=50
API_FOOTBALL_LEAGUE_IDS=
API_FOOTBALL_SEASON=

# The Odds API fills missing Home/Draw/Away prices on rescued API-Football fixtures.
ODDS_API_ENABLED=true
ODDS_API_KEY=
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4
ODDS_API_REGIONS=eu,uk
ODDS_API_MAX_SPORTS=45
ODDS_API_SPORT_KEYS=
ODDS_API_BOOKMAKERS=
ODDS_API_TIMEOUT_MS=20000

# Six-day board = today plus the next five days.
PREDICTION_DAYS=6
PREDICTION_TIMEZONE=Africa/Accra

# Leave blank to keep all countries and leagues.
INCLUDED_COUNTRIES=
EXCLUDED_COUNTRIES=
EXCLUDED_LEAGUE_IDS=

# Optional aliases when provider team names differ from historical names.
TEAM_ALIASES_JSON={}
