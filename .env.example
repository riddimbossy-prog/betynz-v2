# Frontend
VITE_API_BASE_URL=http://localhost:8787

# API
PORT=8787
CORS_ORIGINS=http://localhost:5173,https://betynz.com,https://www.betynz.com
ADMIN_IMPORT_TOKEN=replace-with-a-long-random-secret

# Supabase server credentials. Never put the service-role key in the frontend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Current fixture source: hybrid, betexplorer or api-football.
# Hybrid uses BetExplorer 1X2 values when available and API-Football for fixture metadata
# and extended markets. If one source fails, the other can continue.
FIXTURE_PROVIDER=hybrid

# BetExplorer public-page collector.
# Enable only after reviewing the site's current terms and robots rules.
BETEXPLORER_ENABLED=false
BETEXPLORER_BASE_URL=https://www.betexplorer.com
BETEXPLORER_FIXTURE_URL_TEMPLATE=https://www.betexplorer.com/next/soccer/?year={YYYY}&month={MM}&day={DD}
# Optional fallback templates separated by semicolons.
BETEXPLORER_FALLBACK_URL_TEMPLATES=
BETEXPLORER_RATE_MS=1800
BETEXPLORER_TIMEOUT_MS=20000
BETEXPLORER_MAX_PAGES=18
BETEXPLORER_UTC_OFFSET_MINUTES=0
BETEXPLORER_USER_AGENT=Betynz-Internal-Analytics/2.2 (+https://betynz.com)

# Stable all-league provider and extended odds fallback.
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_MAX_ODDS_PAGES=50

# Six-day board = today plus the next five days.
PREDICTION_DAYS=6
PREDICTION_TIMEZONE=Africa/Accra

# Leave blank to fetch every league available to your API-Football plan.
# Do not set 39 unless you intentionally want EPL only.
API_FOOTBALL_LEAGUE_IDS=
API_FOOTBALL_SEASON=

# Optional filters. Leave blank for all countries and leagues.
INCLUDED_COUNTRIES=
EXCLUDED_COUNTRIES=
EXCLUDED_LEAGUE_IDS=

# Optional aliases when provider team names differ from historical names.
# Example: {"manchesterunited":"manunited","parissaintgermain":"psg"}
TEAM_ALIASES_JSON={}
