# Frontend
VITE_API_BASE_URL=http://localhost:8787

# API
PORT=8787
CORS_ORIGINS=http://localhost:5173,https://betynz.com,https://www.betynz.com
ADMIN_IMPORT_TOKEN=replace-with-a-long-random-secret

# Supabase server credentials. Never put the service-role key in the frontend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# API-Football is the primary fixture/odds provider. BetExplorer remains available only for manual/admin tooling.
FIXTURE_PROVIDER=api-football
BETEXPLORER_ENABLED=false
BETEXPLORER_BASE_URL=https://www.betexplorer.com
BETEXPLORER_UTC_OFFSET_MINUTES=0
BETEXPLORER_BROWSER_RATE_MS=2200
BETEXPLORER_LEAGUE_PAGE_LIMIT=120
BETEXPLORER_NO_NEW_STOP=30
BETEXPLORER_MIN_LEAGUE_PAGES=60
BETEXPLORER_BROWSER_JITTER_MS=700
BETEXPLORER_INTELLIGENCE_TAB_LIMIT=3

# Primary fixture provider.
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_TIMEZONE=Africa/Accra
API_FOOTBALL_MAX_ODDS_PAGES=50
API_FOOTBALL_LEAGUE_IDS=
API_FOOTBALL_SEASON=

# Historical results/HT-FT hydration. Previous-season fallback is required
# when a newly opened season has upcoming fixtures but no completed matches.
API_FOOTBALL_HISTORY_ENABLED=true
API_FOOTBALL_HISTORY_DAYS=540
API_FOOTBALL_HISTORY_MAX_LEAGUES=18
API_FOOTBALL_HISTORY_CONCURRENCY=3
API_FOOTBALL_HISTORY_MIN_TEAM_MATCHES=6
API_FOOTBALL_HISTORY_MIN_LEAGUE_MATCHES=40
API_FOOTBALL_HISTORY_PREVIOUS_SEASON_ENABLED=true

# Six-day board = today plus the next five days.
PREDICTION_DAYS=6
PREDICTION_TIMEZONE=Africa/Accra
PIPELINE_STARTUP_REBUILD_ENABLED=true
PIPELINE_DAILY_REBUILD_ENABLED=true
PIPELINE_DAILY_HOUR=3
PIPELINE_DAILY_MINUTE=15
PIPELINE_PUBLIC_REFRESH_COOLDOWN_MS=300000

# Leave blank to keep all countries and leagues.
INCLUDED_COUNTRIES=
EXCLUDED_COUNTRIES=
EXCLUDED_LEAGUE_IDS=

# Optional aliases when provider team names differ from historical names.
TEAM_ALIASES_JSON={}

# Athena Transition Engine v1.0-RC1 frozen shadow mode
ATHENA_SHADOW_ENABLED=true
ATHENA_HISTORY_LIMIT=24
ATHENA_MIN_HTFT_SAMPLE=6

# Premium Odds API fallback. Keep the real key in Render secrets only.
ODDS_API_KEY=
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4
ODDS_API_FALLBACK_ENABLED=true
ODDS_API_FALLBACK_MIN_FIXTURES=80
ODDS_API_FALLBACK_MIN_EXTENDED_FIXTURES=30
ODDS_API_FALLBACK_MIN_1X2_COVERAGE=0.95
ODDS_API_FALLBACK_MIN_EXTENDED_COVERAGE=0.60
ODDS_API_REGIONS=eu,uk
ODDS_API_MARKETS=h2h,totals
ODDS_API_MAX_SPORTS=45
ODDS_API_CONCURRENCY=3
ODDS_API_SPORT_KEYS=
ODDS_API_HISTORY_MAX_DAYS=7

# Athena is frozen but its qualified picks are public on the God Picks board.
ATHENA_PUBLIC_ENABLED=true

# Betynz 3.0 Olympian engine roles
CHRONOS_ENGINE_ENABLED=true
ATHENA_ENGINE_ENABLED=true
ARES_ENGINE_ENABLED=true
ZEUS_ENGINE_ENABLED=true
CHRONOS_PUBLIC_ENABLED=true
ARES_PUBLIC_ENABLED=true
ZEUS_PUBLIC_ENABLED=true
# Zeus only publishes banker picks with odds strictly below 1.60.
ZEUS_MAX_ODDS_EXCLUSIVE=1.60
