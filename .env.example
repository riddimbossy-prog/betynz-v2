# Frontend
VITE_API_BASE_URL=http://localhost:8787

# API
PORT=8787
CORS_ORIGINS=http://localhost:5173,https://betynz.com,https://www.betynz.com
ADMIN_IMPORT_TOKEN=replace-with-a-long-random-secret

# Supabase server credentials. Never put the service-role key in the frontend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# BetExplorer is the primary upcoming-fixture and 1X2 odds source in v2.3.
FIXTURE_PROVIDER=betexplorer
BETEXPLORER_ENABLED=true
BETEXPLORER_BASE_URL=https://www.betexplorer.com
BETEXPLORER_FIXTURE_URL_TEMPLATE=https://www.betexplorer.com/football/?year={YYYY}&month={MM}&day={DD}
BETEXPLORER_FALLBACK_URL_TEMPLATES=https://www.betexplorer.com/next/soccer/?year={YYYY}&month={MM}&day={DD};https://www.betexplorer.com/?year={YYYY}&month={MM}&day={DD}
BETEXPLORER_DISCOVERY_URLS=https://www.betexplorer.com/football/;https://www.betexplorer.com/next/soccer/
BETEXPLORER_RATE_MS=1800
BETEXPLORER_TIMEOUT_MS=25000
BETEXPLORER_MAX_PAGES=24
BETEXPLORER_UTC_OFFSET_MINUTES=0
BETEXPLORER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 Chrome/124 Safari/537.36

# Optional provider retained for later enrichment. It is ignored while FIXTURE_PROVIDER=betexplorer.
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_TIMEZONE=Africa/Accra
API_FOOTBALL_MAX_ODDS_PAGES=50
API_FOOTBALL_LEAGUE_IDS=
API_FOOTBALL_SEASON=

# Six-day board = today plus the next five days.
PREDICTION_DAYS=6
PREDICTION_TIMEZONE=Africa/Accra

# Leave blank to keep all countries and leagues.
INCLUDED_COUNTRIES=
EXCLUDED_COUNTRIES=
EXCLUDED_LEAGUE_IDS=

# Optional aliases when provider team names differ from historical names.
TEAM_ALIASES_JSON={}
